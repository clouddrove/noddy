# Directory holding this script and its toyland/ payload.
#
# Resolve symlinks rather than using dirname "$0" directly: package managers
# install the script into a versioned directory and symlink it onto PATH, and
# the plain dirname then points at the symlink's directory, where toyland/
# does not exist.
MAC="$0"
while [ -L "$MAC" ]; do
    link=$(readlink "$MAC")
    case "$link" in
        /*) MAC="$link" ;;
        *)  MAC="$(dirname "$MAC")/$link" ;;
    esac
done
MAC="$(cd "$(dirname "$MAC")" && pwd)"

#--------------------------------------------------------------------
# Configuration
#--------------------------------------------------------------------
# Homebrew prefix differs by architecture: /opt/homebrew on Apple Silicon,
# /usr/local on Intel. Everything else is derived from it.
export brew_prefix="$(brew --prefix 2>/dev/null || echo /usr/local)"
export cli_path="${brew_prefix}/bin/"
export plugins_path="${brew_prefix}/bin/toyland/"
export echocommand="false"
export pref_editor="vim"

#--------------------------------------------------------------------
# Parameters
#--------------------------------------------------------------------
export fn=$1
export firstParameter=$2
export secondParameter=$3
export allParameters=${@:2}

#--------------------------------------------------------------------
# Colors
