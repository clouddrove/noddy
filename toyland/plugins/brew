#!/bin/sh

#--------------------------------------------------------------------
# Homebrew Utilities
#--------------------------------------------------------------------

case "$fn" in
    
    # Install macOS software updates, update installed  Homebrew, npm, pip and their installed packages
    # "update" is the name the README documents for this.
    "brew:update"|"update")
        
        echo "Updating macOS..."
        if [ "$echocommand" == "true" ]; then
            echo "${GREEN}sudo softwareupdate -i -a;\n${NC}"
        fi
        sudo softwareupdate -i -a;
        
        echo "Updating Homebrew and its installed packages..."
        # brew prune and brew cask cleanup were removed from Homebrew;
        # brew cleanup now covers both.
        if [ "$echocommand" == "true" ]; then
            echo "${GREEN}brew update; brew upgrade; brew cleanup;\n${NC}"
        fi
        brew update; brew upgrade; brew cleanup;

        if command -v npm > /dev/null; then
            echo "Updating npm and its installed packages..."
            if [ "$echocommand" == "true" ]; then
                echo "${GREEN}npm install npm -g; npm update -g;\n${NC}"
            fi
            npm install npm -g; npm update -g;
        fi

        # macOS ships no "pip"; Homebrew Python provides pip3 and marks the
        # environment externally managed, so packages need --break-system-packages.
        if command -v pip3 > /dev/null; then
            echo "Updating installed pip packages..."
            if [ "$echocommand" == "true" ]; then
                echo "${GREEN}pip3 list --outdated --format=freeze --user | cut -d = -f 1 | xargs -n1 pip3 install --user -U\n${NC}"
            fi
            pip3 list --outdated --format=freeze --user | grep -v '^\-e' | cut -d = -f 1 | xargs -n1 pip3 install --user -U
        fi

    ;;
esac

