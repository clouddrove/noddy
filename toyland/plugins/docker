#!/bin/sh

#--------------------------------------------------------------------
# Docker Utilities
#--------------------------------------------------------------------
case "$fn" in
    "docker:list")
        echo "Showing running containers..."
        if [ "$echocommand" == "true" ]; then
            echo "${GREEN}docker ps;\n${NC}"
        fi
        docker ps -a;
    ;;
    "docker:images")
        echo "Showing docker images..."
        if [ "$echocommand" == "true" ]; then
            echo "${GREEN}show docker images;\n${NC}"
        fi
        docker images;
    ;;
    "docker:remove-images")
        echo "Remove docker images..."
        if [ "$echocommand" == "true" ]; then
            echo "${GREEN}remove docker images;\n${NC}"
        fi
        docker rmi $(docker images -a -q)
    ;;
    "docker:stop")
        echo "Stop docker container..."
        if [ "$echocommand" == "true" ]; then
            echo "${GREEN}stop docker container ;\n${NC}"
        fi
        docker stop $(docker ps -a -q)
    ;;
    "docker:remove")
        echo "Remove docker container..."
        if [ "$echocommand" == "true" ]; then
            echo "${GREEN}remove docker container;\n${NC}"
        fi
        docker rm $(docker ps -a -q)
    ;;
    "docker:prune")
        echo "Remove unused docker data..."
        if [ "$echocommand" == "true" ]; then
            echo "${GREEN}docker system prune;\n${NC}"
        fi
        docker system prune;
    ;;
    # docker-machine reached end of life; on Apple Silicon the runtime is
    # either Docker Desktop or Colima.
    "docker:start")
        if command -v colima > /dev/null; then
            echo "Starting Colima..."
            if [ "$echocommand" == "true" ]; then
                echo "${GREEN}colima start;\n${NC}"
            fi
            colima start;
        elif [ -d /Applications/Docker.app ]; then
            echo "Starting Docker Desktop..."
            if [ "$echocommand" == "true" ]; then
                echo "${GREEN}open -a Docker;\n${NC}"
            fi
            open -a Docker;
        else
            echo "${RED}No Docker runtime found${NC} - install one with ${GREEN}brew install colima${NC} or ${GREEN}brew install --cask docker${NC}"
            exit 1
        fi
    ;;
    "docker:restart")
        if command -v colima > /dev/null; then
            echo "Restarting Colima..."
            if [ "$echocommand" == "true" ]; then
                echo "${GREEN}colima restart;\n${NC}"
            fi
            colima restart;
        elif [ -d /Applications/Docker.app ]; then
            echo "Restarting Docker Desktop..."
            if [ "$echocommand" == "true" ]; then
                echo "${GREEN}killall Docker && open -a Docker;\n${NC}"
            fi
            killall Docker; open -a Docker;
        else
            echo "${RED}No Docker runtime found${NC} - install one with ${GREEN}brew install colima${NC} or ${GREEN}brew install --cask docker${NC}"
            exit 1
        fi
    ;;
esac
