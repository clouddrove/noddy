#!/bin/sh

# Colors
GREEN='\033[0;32m'
LIGHTGREEN='\033[1;32m'
LIGHTBLUE='\033[01;34m'
RED='\033[1;31m'
NC='\033[0m' # No Color

# Repository root: this script lives in toyland/setup/
PACKAGE_DIRECTORY="$( cd "$( dirname "$0" )/../.." && pwd )"

main() {

    echo "${LIGHTBLUE}================================================"
    echo " noddy  Installer"
    echo "================================================${NC}\n"

    # When piped through curl there is no checkout around this script, so fetch one.
    if [ ! -f "$PACKAGE_DIRECTORY/noddy" ]; then
        if ! command -v git > /dev/null; then
            echo "${RED}git is required to download noddy.${NC}"
            exit 1
        fi
        WORKDIR="$(mktemp -d)"
        trap 'rm -rf "$WORKDIR"' EXIT
        echo "Downloading noddy..."
        git clone https://github.com/clouddrove/noddy.git --depth 1 "$WORKDIR/noddy" > /dev/null 2>&1 \
            || { echo "${RED}Could not clone https://github.com/clouddrove/noddy.git${NC}"; exit 1; }
        PACKAGE_DIRECTORY="$WORKDIR/noddy"
    fi

    # Homebrew first: its prefix decides where noddy and every dependency land.
    # Apple Silicon uses /opt/homebrew, Intel uses /usr/local.
    if ! command -v brew > /dev/null; then
        echo "Installing homebrew..."
        echo "${GREEN}/bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\"\n${NC}"
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

        for candidate in /opt/homebrew/bin/brew /usr/local/bin/brew; do
            if [ -x "$candidate" ]; then
                eval "$($candidate shellenv)"
                break
            fi
        done
    fi

    if ! command -v brew > /dev/null; then
        echo "${RED}Homebrew is required but was not installed.${NC}"
        exit 1
    fi

    BREW_PREFIX="$(brew --prefix)"
    INSTALL_DIR="${BREW_PREFIX}/bin"
    echo "Installing to ${INSTALL_DIR}\n"

    # Set NODDY_NONINTERACTIVE=1 to accept every default and skip the optional
    # extras. Used by CI, and useful for any unattended install.
    ask() {
        if [ -n "$NODDY_NONINTERACTIVE" ]; then
            response="$2"
            return 0
        fi
        printf "${LIGHTGREEN}"
        read -r -p "$1 " response
        printf "${NC}"
    }

    ask "Would you like noddy to show you the commands that are run on each mac command? (Yes / No)" "No"

    if [ ! -d "$INSTALL_DIR" ]; then
        echo "Creating ${INSTALL_DIR}..."
        mkdir -p "$INSTALL_DIR" || { echo "${RED}Could not create ${INSTALL_DIR}${NC}"; exit 1; }
    fi

    rm -rf "${INSTALL_DIR}/toyland"
    cp "$PACKAGE_DIRECTORY/noddy" "${INSTALL_DIR}/noddy"
    cp -R "$PACKAGE_DIRECTORY/toyland" "${INSTALL_DIR}/toyland"
    chmod +x "${INSTALL_DIR}/noddy"
    chmod -R +x "${INSTALL_DIR}/toyland"

    # Rewrite the installed copy, never the checkout.
    case $response in
        [yY][eE][sS]|[yY])
            LC_CTYPE=C sed -i'' -e 's#echocommand="false"#echocommand="true"#g' "${INSTALL_DIR}/noddy"
        ;;
        *)
        ;;
    esac

    if [ -n "$NODDY_NONINTERACTIVE" ]; then
        pref_editor=""
    else
        echo "${LIGHTGREEN}Please enter your favourite text editor (by entering the command that opens your favourite editor. i.e: nano):"
        echo "${NC}Press enter without any value to keep default: vim"
        read pref_editor
    fi
    if [ -n "$pref_editor" ] && [ "$pref_editor" != " " ]; then
        LC_CTYPE=C sed -i'' -e "s#pref_editor=\"vim\"#pref_editor=\"${pref_editor}\"#g" "${INSTALL_DIR}/noddy"
    fi

    # Shell completions. Homebrew already puts these directories on the
    # relevant search paths, so no shell config edit is needed for bash or
    # fish. Zsh additionally needs site-functions on $fpath; see the README.
    install_completion() {
        target_dir="$1"
        source_file="$2"
        target_name="$3"
        mkdir -p "$target_dir" 2>/dev/null || return 0
        cp "$PACKAGE_DIRECTORY/toyland/completion/${source_file}" "${target_dir}/${target_name}" 2>/dev/null \
            && echo "  completion: ${target_dir}/${target_name}"
    }

    echo "Installing shell completions..."
    install_completion "${BREW_PREFIX}/share/zsh/site-functions" "_noddy" "_noddy"
    install_completion "${BREW_PREFIX}/etc/bash_completion.d" "noddy.bash" "noddy"
    install_completion "${BREW_PREFIX}/share/fish/vendor_completions.d" "noddy.fish" "noddy.fish"

    # Only what the plugins actually reach for: git for the git commands, pv
    # for the tar:compress progress bar, wget for ip:public, fdupes for
    # find:duplicated. node and python3 used to be installed here, but nothing
    # needs them unless you opt into Fast CLI or Glances below, so they are
    # installed by those branches instead.
    #
    # command -v rather than brew list, so a tool already on PATH from another
    # source counts and Homebrew is never invoked for it.
    for pkg in git pv wget fdupes; do
        if ! command -v "$pkg" > /dev/null; then
            echo "Installing ${pkg}..."
            echo "${GREEN}brew install ${pkg}\n${NC}"
            brew install "$pkg"
        fi
    done

    if ! command -v glances > /dev/null; then
        ask "Would you like to install Glances to access advanced information about the system (https://github.com/nicolargo/glances)? (Yes / No)" "No"
        case $response in
            [yY][eE][sS]|[yY])
                echo "Installing Glances (https://github.com/nicolargo/glances)..."
                # Homebrew Python is externally managed, so pip install fails here.
                echo "${GREEN}brew install glances\n${NC}"
                brew install glances
            ;;
            *)
            ;;
        esac
    fi

    if ! command -v fast > /dev/null; then
        ask "Would you like to install Fast CLI to run internet speed tests from your command line (https://github.com/sindresorhus/fast-cli)? (Yes / No)" "No"
        case $response in
            [yY][eE][sS]|[yY])
                echo "Installing Fast CLI (https://github.com/sindresorhus/fast-cli)..."
                if ! command -v npm > /dev/null; then
                    echo "${GREEN}brew install node\n${NC}"
                    brew install node
                fi
                echo "${GREEN}npm install --global fast-cli\n${NC}"
                npm install --global fast-cli
            ;;
            *)
            ;;
        esac
    fi

    if ! command -v istats > /dev/null; then
        ask "Would you like to install iStats to access information about your Mac temperature and fan speed? (Yes / No)" "No"
        case $response in
            [yY][eE][sS]|[yY])
                echo "Installing iStats..."
                # macOS 12.3 removed the system Ruby, so iStats needs a Homebrew Ruby.
                if ! brew list --formula ruby > /dev/null 2>&1; then
                    echo "${GREEN}brew install ruby\n${NC}"
                    brew install ruby
                fi
                echo "${GREEN}gem install iStats\n${NC}"
                gem install iStats
            ;;
            *)
            ;;
        esac
    fi

    echo "\n${GREEN}noddy installed. Run 'noddy help' to get started.${NC}"
    case ":$PATH:" in
        *":${INSTALL_DIR}:"*) ;;
        *) echo "${RED}${INSTALL_DIR} is not on your PATH.${NC} Add it in your shell config, then re-open your terminal." ;;
    esac
}

main
